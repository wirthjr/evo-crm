# EvoAI Core Service Configuration
# Copy this file to .env and adjust the values according to your environment

# Application Configuration
PORT=5555

# Database Configuration (PostgreSQL)
# IMPORTANT: Use the EXACT same database as your Evolution instance
# Based on your Evolution .env: POSTGRES_DATABASE=evo_chat
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=root
DB_NAME=evo_community
DB_SSLMODE=disable

# Database Performance Optimization
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=30m

# JWT Token Validation
# IMPORTANT: This MUST be the exact same value as SECRET_KEY_BASE in your Evolution .env
# From your Evolution: SECRET_KEY_BASE=<same value from your shared .env>
JWT_SECRET_KEY=<same_as_secret_key_base>
JWT_ALGORITHM=HS256

# Fernet encryption key for API keys (shared with evo-ai-processor)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<generate_with_fernet>

# Evolution Integration
# Use the same FRONTEND_URL from your Evolution .env
# From your Evolution: FRONTEND_URL=https://d6f6b89f6421.ngrok-free.app
EVOLUTION_BASE_URL=http://localhost:3000

# EvoAuth Integration
# EvoAuth Service Configuration
EVO_AUTH_BASE_URL=http://localhost:3001

# AI Processor Service Configuration
AI_PROCESSOR_URL=http://localhost:8000
AI_PROCESSOR_VERSION=v1

# Global rate limiting (applies to all requests)
RATE_LIMIT_GLOBAL_RPS=1000
RATE_LIMIT_GLOBAL_BURST=50

RATE_LIMIT_CLIENT_RPS=100
RATE_LIMIT_CLIENT_BURST=10

# Rate limiter cleanup interval
RATE_LIMIT_CLEANUP_INTERVAL=5m

# Health check timeouts
HEALTH_CHECK_TIMEOUT=5s
READINESS_CHECK_TIMEOUT=2s

# Database health check query
DB_HEALTH_CHECK_QUERY=SELECT 1

# Connection pool thresholds for health monitoring
DB_CONN_THRESHOLD_DEGRADED=90
DB_WAIT_COUNT_THRESHOLD=100

# Memory thresholds (in MB)
MEMORY_THRESHOLD_WARNING=400
MEMORY_THRESHOLD_CRITICAL=500

# Development Configuration
# Uncomment the line below to enable development mode with hot reload
# DEV_MODE=true

