# Allow the install to proceed when a transitive peerDependency can't be
# satisfied. This is required right now because react-i18next 15 declares
# an optional peerDependency on typescript ^5, but the dashboard pins
# typescript ~6.0. The peer is optional and the library works on TS 6, so
# we accept the old peer-resolver behavior across the whole workspace.
legacy-peer-deps=true
