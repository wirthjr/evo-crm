<% @messages.each do |message| %>
  <p style="font-family: Roboto,"Helvetica Neue",Tahoma,Arial,sans-serif; text-align: start; unicode-bidi: plaintext;">
    <% if message.content %>
      <%
        # Check if content is already HTML (from email templates)
        content = message.content.strip
        is_html = content.start_with?('<!DOCTYPE') ||
                  content.start_with?('<html') ||
                  content.start_with?('<!doctype') ||
                  (content.start_with?('<') && content.include?('</'))

        if is_html
      %>
        <%= content.html_safe %>
      <% else %>
        <%= EvolutionMarkdownRenderer.new(message.content).render_message %>
      <% end %>
    <% end %>
    <% if message.attachments.present? %>
      <p>Attachments:</p>
      <% message.attachments.each do |attachment| %>
        <p><a href="<%= attachment.file_url %>" target="_blank"><%= attachment.file.filename.to_s %></a></p>
      <% end %>
    <% end %>
  </p>
<% end %>
<% if @channel&.email_signature.present? %>
  <div style="margin-top: 20px; border-top: 1px solid #e0e0e0; padding-top: 12px;">
    <%= @channel.email_signature.html_safe %>
  </div>
<% end %>
