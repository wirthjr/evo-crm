# Evo Auth Service Environment Configuration
# 100% Compatible with Evolution Authentication System
# Copy this file to .env and update the values for your environment

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DATABASE=evo_community

# =============================================================================
# RAILS CONFIGURATION (Required)
# =============================================================================
RAILS_ENV=development
RAILS_MAX_THREADS=5
SECRET_KEY_BASE=generate_with_rails_secret_command

# =============================================================================
# DOORKEEPER JWT CONFIGURATION (Required for OAuth2 JWT tokens)
# =============================================================================
# Generate with: rails secret (or use the same as SECRET_KEY_BASE)
DOORKEEPER_JWT_SECRET_KEY=generate_with_rails_secret_command
DOORKEEPER_JWT_ALGORITHM=hs256
DOORKEEPER_JWT_ISS=evo-auth-service
DOORKEEPER_JWT_AUD=[]

# =============================================================================
# REDIS CONFIGURATION (Required for background jobs)
# =============================================================================
REDIS_URL=redis://localhost:6379/1

# =============================================================================
# SIDEKIQ CONFIGURATION (Required for background jobs)
# =============================================================================
SIDEKIQ_CONCURRENCY=10
# Set to sidekiq for worker containers so Docker healthcheck validates the
# Sidekiq process instead of probing the web /health endpoint.
SERVICE_ROLE=web
# Set to true to make the image healthcheck exit successfully without probing.
DISABLE_HEALTHCHECK=false

# =============================================================================
# APPLICATION URLS (Required)
# =============================================================================
FRONTEND_URL=http://localhost:5173

# =============================================================================
# INTERNAL SERVICE AUTH (Optional - service-to-service calls)
# =============================================================================
# Token accepted in X-Service-Token / X-Internal-API-Token headers
EVOAI_CRM_API_TOKEN=6e10e689-58ce-4416-bf0d-f5818bf2dcf8
# Optional service-specific alias (if set, it takes precedence)
# EVOAI_AUTH_API_TOKEN=6e10e689-58ce-4416-bf0d-f5818bf2dcf8

# =============================================================================
# EMAIL CONFIGURATION (Required for password reset, MFA)
# =============================================================================
MAILER_SENDER_EMAIL=noreply@evo-auth-service.com

# SMTP Configuration (Required for email delivery)
# Values configured via Admin Settings UI take precedence over these ENV vars (UI > ENV > default).
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_AUTHENTICATION=login
SMTP_DOMAIN=yourdomain.com
SMTP_ENABLE_STARTTLS_AUTO=true

# MFA Configuration
MFA_ISSUER=EvoAI

# Optional SMTP Settings
# SMTP_SSL=false
# SMTP_TLS=false
# SMTP_OPENSSL_VERIFY_MODE=peer
# SMTP_OPEN_TIMEOUT=5
# SMTP_READ_TIMEOUT=5

# =============================================================================
# ADVANCED EMAIL PROVIDERS (Optional - Higher Priority than SMTP)
# =============================================================================

# BMS (Brius Message System) Configuration
# If configured, BMS will be used instead of SMTP for email delivery
# BMS_API_KEY=your_bms_api_key_here
# BMS_IPPOOL=default

# Resend Email Service Configuration
# If configured and BMS is not available, Resend will be used instead of SMTP
# RESEND_API_KEY=your_resend_api_key_here

# =============================================================================
# CLOUD STORAGE CONFIGURATION (Required for file uploads in production)
# =============================================================================
# Options: local, amazon, s3_compatible
ACTIVE_STORAGE_SERVICE=local

# S3-compatible storage (Cloudflare R2, Backblaze B2, Minio, DigitalOcean Spaces)
# STORAGE_BUCKET_NAME=your_bucket_name
# STORAGE_ACCESS_KEY_ID=your_access_key_id
# STORAGE_SECRET_ACCESS_KEY=your_secret_access_key
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Amazon S3
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your_bucket_name

# =============================================================================
# SHARED ENCRYPTION KEY (Required for reading encrypted configs from CRM)
# =============================================================================
# Must match the ENCRYPTION_KEY used by the CRM service
# Generate with: ruby -e "require 'securerandom'; puts Base64.urlsafe_encode64(SecureRandom.random_bytes(32))"
ENCRYPTION_KEY=

# =============================================================================
# OPTIONAL CONFIGURATIONS
# =============================================================================

# Google OAuth (for social login - optional)
# GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
# GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# CORS Configuration (optional - defaults work for development)
# EVOLUTION_API_ONLY_SERVER=false
# ENABLE_API_CORS=false

# Production Configuration (uncomment for production)
# RAILS_LOG_LEVEL=info
# PORT=3001

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Generate secret key: rails secret
# 3. Update POSTGRES_PASSWORD with your PostgreSQL password
# 4. Update MAILER_SENDER_EMAIL if needed
# 5. Start the service: make start
