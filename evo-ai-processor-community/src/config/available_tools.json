    "tools": [
        {
            "id": "text_to_speech",
            "name": "text_to_speech",
            "description": "Convert text to speech using ElevenLabs",
            "tags": [
                "audio",
                "synthesis",
                "ai",
                "elevenlabs"
            ],
            "examples": [
                "Create narration for videos",
                "Generate audio for accessibility",
                "Produce podcast content"
            ],
            "inputModes": [
                "text/plain"
            ],
            "outputModes": [
                "audio/mp3",
                "audio/wav",
                "audio/mpeg"
            ],
            "config": {
                "required_fields": [
                    "eleven_labs_token",
                    "voice_id"
                ],
                "optional_fields": [
                    "model_id",
                    "stability",
                    "similarity_boost",
                    "style",
                    "use_speaker_boost",
                    "speed"
                ],
                "default_values": {
                    "model_id": "eleven_multilingual_v2",
                    "stability": 0.5,
                    "similarity_boost": 0.75,
                    "style": 0.0,
                    "use_speaker_boost": true,
                    "speed": 1.0
                },
                "field_types": {
                    "eleven_labs_token": "string",
                    "voice_id": "string",
                    "model_id": "string",
                    "stability": "float",
                    "similarity_boost": "float",
                    "style": "float",
                    "use_speaker_boost": "boolean",
                    "speed": "float"
                },
                "max_text_length": 5000
            }
        },
